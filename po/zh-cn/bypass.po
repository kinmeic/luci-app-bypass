msgstr "BypassCore 国内 DNS"

msgid "Upstream for domestic domains in the BypassCore DNS section."
msgstr "BypassCore DNS 配置中用于国内域名的上游。"

msgid "BypassCore remote DNS"
msgstr "BypassCore 远程 DNS"

msgid "Domestic split domain"
msgstr "国内分流域名"

msgid "Redirect dnsmasq to ChinaDNS-NG"
msgstr "将 dnsmasq 重定向到 ChinaDNS-NG"

msgid "Force special DNS server to need proxy devices."
msgstr "强制需要代理的设备使用专用 DNS 服务器。"

