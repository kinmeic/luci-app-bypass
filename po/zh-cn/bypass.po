msgid "BypassCore routing engine"
msgstr "BypassCore 分流引擎"

msgid ""
"Select BypassCore mode when shunt rules, blocking rules, or UDP TPROXY must "
"be enforced on live traffic. It requires a compatible BypassCore binary."
msgstr ""
"需要让自定义分流规则、阻断规则或 UDP TPROXY 对实时流量生效时，请选择 "
"BypassCore 模式；该模式需要兼容的 BypassCore 二进制。"

msgid "Node Socks Listen Port"
msgstr "节点 SOCKS 监听端口"

msgid "Node Socks Bind Local"
msgstr "节点 SOCKS 仅绑定本机"

msgid "When selected, it can only be accessed localhost."
msgstr "当勾选时，只能本机访问。"

msgid "BypassCore binary"
msgstr "BypassCore 二进制"

msgid "naive binary"
msgstr "naive 二进制"

msgid "chinadns-ng binary"
msgstr "chinadns-ng 二进制"

msgid "Default Egress Interface"
msgstr "默认出口接口"

msgid ""
"Steer the naive → server tunnel out of this interface. Empty = system "
"default route."
msgstr "将 naive → 服务器隧道从此接口发出；留空则使用系统默认路由。"

msgid "(system default route)"
msgstr "（系统默认路由）"

msgid "Egress fwmark"
msgstr "出口 fwmark"

msgid "Enter a decimal or hexadecimal mark, for example 2 or 0x2."
msgstr "请输入十进制或十六进制标记，例如 2 或 0x2。"

msgid "Egress route table"
msgstr "出口路由表"

msgid "Egress rule priority"
msgstr "出口规则优先级"

msgid "Priority of the destination policy rules. The default 900 runs before Passwall2/mwan3-style marked rules without modifying their packet marks."
msgstr "目标策略规则的优先级。默认值 900 会先于 Passwall2/mwan3 风格的标记规则执行，且不会修改其数据包标记。"

msgid "Steer the NaiveProxy server connection out of this OpenWrt network (wan/wan1/usbwan). A node-specific setting overrides this value. Empty = system default route."
msgstr "让 NaiveProxy 服务器连接从此 OpenWrt 网络（wan/wan1/usbwan）发出。节点单独设置会覆盖此值；留空则使用系统默认路由。"

msgid "Start Delay (seconds)"
msgstr "启动延迟（秒）"

msgid ""
"Delay before Bypass starts on boot (lets WAN/DNS settle). 0 = start "
"immediately."
msgstr "开机时延迟启动 Bypass，让 WAN/DNS 先就绪；0 表示立即启动。"

msgid "Domain Strategy"
msgstr "域名解析策略"

msgid ""
"AsIs = no DNS resolution. IpIfNonMatch = resolve on domain mismatch. "
"IpOnDemand = resolve when a rule needs an IP."
msgstr ""
"AsIs = 不解析 DNS；IpIfNonMatch = 域名未命中时解析；IpOnDemand = 规则需要 IP "
"时解析。"

msgid "Default Direct Interface"
msgstr "默认输出接口"

msgid "Bind BypassCore direct traffic to this OpenWrt network. The current runtime L3 device and address are resolved through netifd. Empty = system default route."
msgstr "将 BypassCore 直连流量绑定到此 OpenWrt 网络。程序通过 netifd 解析当前 L3 设备和地址；留空则使用系统默认路由。"

msgid ""
"Bind the direct outbound to this network interface so direct shunt traffic "
"egresses here. Empty = system default route."
msgstr ""
"将直连出站绑定到该网络接口，使分流直连流量从此接口发出。留空则使用系统默认路"
"由。"

msgid "Domestic DNS (china-dns)"
msgstr "国内 DNS（china-dns）"

msgid "\"auto\" = detect ISP DNS from resolv.conf."
msgstr "“auto”表示从 resolv.conf 自动检测运营商 DNS。"

msgid "Remote / Foreign DNS (trust-dns)"
msgstr "国外 DNS（trust-dns）"

msgid "Remote DNS protocol"
msgstr "国外 DNS 协议"

