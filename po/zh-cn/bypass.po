msgstr "域名列表"

msgid "One rule per line."
msgstr "每行一条规则。"

msgid "IP / CIDR list"
msgstr "IP / CIDR 列表"

msgid "Download / refresh geoip.dat and geosite.dat (Loyalsoldier) used by BypassCore geosite:/geoip: rules and the firewall ipset/nftset plane."
msgstr "下载 / 刷新 BypassCore geosite:/geoip: 规则与防火墙 ipset/nftset 平面所使用的 geoip.dat 和 geosite.dat（Loyalsoldier）。"

