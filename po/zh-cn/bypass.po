msgid "Default Egress Interface"
msgstr "默认出口接口"

msgid "Steer the naive -> server tunnel connection out of this interface (dest-IP fwmark policy routing). Leave empty to use the system default route. Per-node egress_interface overrides this."
msgstr "把 naive → 服务器 的隧道连接从该接口发出（基于目的 IP 的 fwmark 策略路由）。留空则使用系统默认路由。每个节点的 egress_interface 可覆盖此项。"

msgid "Egress fwmark"
msgstr "出口 fwmark"

msgid "Firewall mark used to steer naive traffic. Advanced."
msgstr "用于引导 naive 流量的防火墙标记（高级）。"

msgid "Egress route table"
msgstr "出口路由表"

msgid "Routing table id used for the egress policy rule. Advanced."
msgstr "出口策略规则使用的路由表 ID（高级）。"

msgid "Default Direct Interface"
msgstr "默认输出接口"

msgid "Bind the direct outbound to this network interface so direct shunt traffic egresses here. Empty = system default route."
msgstr "将直连出站绑定到该网络接口，使分流直连流量从此接口发出。留空则使用系统默认路由。"

msgid "Transparent-proxy redirect settings."
msgstr "透明代理重定向设置。"

msgid "Ports & Mode"
msgstr "端口与模式"

msgid "TCP redirect ports"
msgstr "TCP 重定向端口"

msgid "Port range or list. \"1:65535\" redirects all TCP. Use \"disable\" to disable."
msgstr "端口范围或列表。“1:65535” 重定向所有 TCP。填 “disable” 可禁用。"

msgid "UDP redirect ports"
msgstr "UDP 重定向端口"

msgid "TCP no-redirect ports"
msgstr "TCP 不重定向端口"

msgid "Ports to leave direct. \"disable\" = none."
msgstr "保持直连的端口。“disable” 表示无。"

msgid "UDP no-redirect ports"
msgstr "UDP 不重定向端口"

msgid "Transparent mode"
msgstr "透明代理模式"

msgid "Redirect (REDIRECT, TCP)"
msgstr "Redirect（REDIRECT，仅 TCP）"

msgid "TPROXY (TCP + UDP)"
msgstr "TPROXY（TCP + UDP）"

msgid "TUN (naive manages routing)"
msgstr "TUN（由 naive 管理路由）"

msgid "naive listen mode. \"redirect\" = TCP only; \"tproxy\" = TCP+UDP (needs kmod-nft-tproxy); \"tun\" = naive creates a tun device."
msgstr "naive 监听模式。“redirect” = 仅 TCP；“tproxy” = TCP+UDP（需要 kmod-nft-tproxy）；“tun” = naive 创建 tun 设备。"

msgid "Enable IPv6 TProxy"
msgstr "启用 IPv6 TProxy"

msgid "ChinaDNS-NG split DNS."
msgstr "ChinaDNS-NG 分流 DNS。"

msgid "ChinaDNS-NG"
msgstr "ChinaDNS-NG"

msgid "Domestic DNS (china-dns)"
msgstr "国内 DNS（china-dns）"

msgid "Resolves domestic domains. \"auto\" = detect ISP DNS from resolv.conf."
msgstr "解析国内域名。“auto” 表示从 resolv.conf 自动检测运营商 DNS。"

msgid "Remote / Foreign DNS (trust-dns)"
msgstr "国外 DNS（trust-dns）"

msgid "Resolves foreign domains; their IPs are routed through the proxy."
msgstr "解析国外域名；其解析到的 IP 会走代理。"

msgid "Remote DNS protocol"
msgstr "国外 DNS 协议"

