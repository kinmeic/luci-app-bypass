msgid "Default Direct Interface"
msgstr "默认直连接口"

#: htdocs/luci-static/resources/view/bypass/basic_settings.js
msgid "Default Naive Interface"
msgstr "默认 Naive 接口"

#: htdocs/luci-static/resources/view/bypass/basic_settings.js
msgid "Use this OpenWrt network for NaiveProxy nodes whose Egress Interface is set to use the default Naive interface. Empty = system default route."
