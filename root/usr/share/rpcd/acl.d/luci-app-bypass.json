{
	"luci-app-bypass": {
		"description": "Bypass (NaiveProxy + BypassCore) access",
		"read": {
			"uci": ["bypass"],
			"ubus": {
				"file": ["read", "list", "stat"],
				"system": ["info", "board"],
				"luci": ["getInitList", "setInitAction"]
			},
			"file": [
				"/tmp/log/bypass.log",
				"/tmp/etc/bypass/bypasscore/config.json",
				"/usr/share/bypass/"
			]
		},
		"write": {
			"uci": ["bypass"],
			"ubus": {
				"file": ["exec"]
			},
			"file": {
				"/usr/share/bypass/api.sh": ["exec"]
			}
		}
	}
}
