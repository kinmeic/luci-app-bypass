
config global
	option enabled '0'
	option node_socks_port '1088'
	option node_socks_bind_local '1'
	# URL used by the Node List "URL Test" column (curl through the node's
	# temporary SOCKS listener). generate_204 endpoints return an empty body.
	option url_test_url 'https://www.google.com/generate_204'
	option client_proxy '1'
	option loglevel 'warning'
	# BypassCore is the required routing core. NaiveProxy is its protocol
	# adapter/SOCKS upstream for Naive nodes, never a fallback core.
	option dns_redirect '1'
	# BypassCore binary (install from https://github.com/kinmeic/BypassCore
	# releases; pick the build matching your router's architecture). The
	# routing/split engine + Observatory / route-test / DNS-resolve pages
	# auto-disable if the binary/launcher is absent or does not identify itself.
	option bypasscore_file '/usr/bin/bypasscore'
	option naive_file '/usr/bin/naive'
	option chinadns_file '/usr/bin/chinadns-ng'
	option dns2socks_file '/usr/bin/dns2socks'
	# Base table/priority for per-node NaiveProxy egress policy routing. A node's
	# logical interface is configured in its Node Config page.
	option naive_egress_table '20200'
	option naive_egress_rule_priority '900'

config global_forwarding
	option ipv6_tproxy '0'
	option force_proxy_lan_ip '0'
	option accept_icmp '0'
	option tcp_no_redir_ports 'disable'
	option tcp_redir_ports '1:65535'
	option tcp_proxy_way 'redirect'

config global_dns
	option domestic_dns 'auto'
	option remote_dns '1.1.1.1'
	option remote_dns_protocol 'tcp'
	option remote_dns_doh 'https://1.1.1.1/dns-query'
	option remote_dns_detour 'remote'
	option direct_dns_query_strategy 'UseIP'
	option remote_dns_query_strategy 'UseIPv4'
	option dns_hosts 'cloudflare-dns.com 1.1.1.1
dns.google.com 8.8.8.8'
	option chinadns_listen_port '10553'
	option dns_split_domain 'geosite:cn'

config global_rules
	option geosite_update '1'
	option geoip_update '1'
	option update_week_mode ''
	option update_time_mode '0:00'
	option update_interval_mode '1'
	option v2ray_location_asset '/usr/share/v2ray/'
	option domainStrategy 'IpOnDemand'
	option domainMatcher 'hybrid'
	option write_ipset_direct '1'
	option enable_geoview_ip '1'
	# Default network interface for the direct outbound (direct shunt traffic).
	# Empty = direct uses the system default route (unbound freedom outbound).
	option direct_egress_interface ''
	option geoip_url 'https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat'
	option geosite_url 'https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geosite.dat'

config global_app
	option geoview_file '/usr/bin/geoview'

config global_delay
	option start_daemon '1'
	option start_delay '60'
	option stop_week_mode ''
	option start_week_mode ''
	option restart_week_mode ''

config shunt_rules 'China'
	option remarks 'China'
	option network 'tcp,udp'
	option domain_list 'geosite:cn'
	option ip_list 'geoip:cn'
	option outbound '_direct'

config shunt_rules 'PrivateIP'
	option remarks 'PrivateIP'
	option network 'tcp,udp'
	option ip_list '0.0.0.0/8
10.0.0.0/8
127.0.0.0/8
169.254.0.0/16
172.16.0.0/12
192.0.0.0/24
192.0.2.0/24
192.88.99.0/24
192.168.0.0/16
198.51.100.0/24
203.0.113.0/24
224.0.0.0/3
100.64.0.0/10'
	option outbound '_direct'

config shunt_rules 'AdBlock'
	option remarks 'AdBlock'
	option network 'tcp,udp'
	option domain_list 'geosite:category-ads-all'
	option outbound '_blackhole'

# Reserved catch-all row.  It is configured in Basic Settings -> Shunt Rule
# and intentionally hidden from Rule Manage.
config shunt_rules 'Default'
	option remarks 'Default'
	option is_default '1'
	option network 'tcp,udp'
	option outbound '_direct'

config nodes 'naive1'
	option remarks 'Example'
	option protocol 'https'
	option address 'naive.example.com'
	option port '443'
	option egress_interface ''
	option username 'user'
	option password 'pass'
